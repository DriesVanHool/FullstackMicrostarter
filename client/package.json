{
  "name": "fullstackmicrostarter-client-workspace",
  "private": true,
  "version": "0.1.0",
  "description": "Frontend workspace for Fullstack Microstarter.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:portal\" \"npm run dev:workspace\"",
    "dev:portal": "npm run dev -w @fullstackmicrostarter/portal",
    "dev:workspace": "npm run dev -w @fullstackmicrostarter/workspace",
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint apps packages --ext .ts,.tsx",
    "test": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^27.1.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^3.2.4"
  }
}
